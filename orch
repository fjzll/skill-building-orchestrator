#!/usr/bin/env bash
# orch — one command for the whole orchestrator.
#   ./orch init <slug> "<Display Name>"   turn a fresh clone into a client repo
#   ./orch up       start the portal + conductor (your normal "on" switch)
#   ./orch grill    start the NEXT grill session (interactive, seeded)
#   ./orch status   pipeline state
#   ./orch doctor   what is stuck, and can this machine run a build
#   ./orch retrospect  per-repo report from artifacts on disk -> analysis/retrospect.md
#   ./orch facts    force the facts pass (conductor also does this automatically)
#   ./orch daemon   run the conductor in the foreground
set -e
cd "$(dirname "$0")"

case "${1:-status}" in
  init)
    SLUG="$2"
    NAME="$3"
    if [ -z "$SLUG" ] || [ -z "$NAME" ]; then
      echo "usage: ./orch init <slug> \"<Display Name>\""; exit 1
    fi
    if [ -f client.yaml ]; then
      echo "client.yaml already exists — refusing to overwrite. Remove it first if you really mean to re-init."
      exit 1
    fi
    TEMPLATE_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
    cat > client.yaml <<EOF
slug: $SLUG
display_name: $NAME
portal_title: Skill Implementation — $NAME
template_commit: $TEMPLATE_COMMIT
EOF
    echo "wrote client.yaml (slug=$SLUG, display_name=$NAME, template_commit=$TEMPLATE_COMMIT)"
    ;;
  up)
    echo "▶ starting conductor (background, log: analysis/conductor.log)"
    nohup python3 runner/conductor.py > /dev/null 2>&1 &
    echo $! > analysis/.conductor-pid
    echo "▶ starting portal at http://localhost:3000"
    cd portal && exec npm run dev
    ;;
  down)
    [ -f analysis/.conductor-pid ] && kill "$(cat analysis/.conductor-pid)" 2>/dev/null && rm analysis/.conductor-pid && echo "conductor stopped" || echo "conductor not running"
    ;;
  grill)
    python3 runner/facts_extractor.py . > /dev/null
    NEXT=$(python3 runner/runner.py next)
    echo "$NEXT"
    if ! echo "$NEXT" | grep -q "grill session"; then
      echo "Nothing to grill — see above."; exit 0
    fi
    SUBJECT=$(echo "$NEXT" | head -1 | sed 's/^NEXT: grill session [0-9]* — //')
    if ! command -v claude >/dev/null; then
      echo ""
      echo "The claude CLI is not installed. Either install it (npm install -g @anthropic-ai/claude-code)"
      echo "or start the session in Cowork with this prompt:"
      echo "-----------------------------------------------------------------------"
      cat docs/grill-seed.txt 2>/dev/null | sed "s/{SUBJECT}/$SUBJECT/"
      exit 0
    fi
    exec claude "$(sed "s/{SUBJECT}/$SUBJECT/" docs/grill-seed.txt)"
    ;;
  facts)      python3 runner/facts_extractor.py . ;;
  daemon)     exec python3 runner/conductor.py "${@:2}" ;;
  status)     python3 runner/runner.py status; echo; python3 runner/runner.py next ;;
  doctor)     exec python3 runner/doctor.py . ;;
  retrospect) exec python3 runner/retrospect.py . ;;
  build)      python3 runner/runner.py build "$2" ;;
  test)       python3 runner/runner.py test "$2" ;;
  *) echo "usage: ./orch [init <slug> \"<Name>\"|up|down|grill|status|doctor|retrospect|facts|daemon|build <skill>|test <skill>]" ;;
esac
